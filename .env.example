# Unified AI API Environment Variables

# AWS Configuration (Required for S3 interactions in Video Moderation)
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
CLOUDFRONT_URL=https://your-cloudfront-url.cloudfront.net
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# HuggingFace Configuration (Required for Pyannote Audio Speaker Diarization)
HF_TOKEN=your_huggingface_token_here

# Optional: Audio Pipeline Overrides
# USE_OVERLAP_HEURISTIC_FALLBACK=False
# AUDIO_WORKER_POOL_SIZE=2
# AUDIO_REQUEST_TIMEOUT_SECONDS=180

# Optional: Photo Pipeline Overrides
# PHOTO_WORKER_POOL_SIZE=4
# PHOTO_BATCH_TIMEOUT_SECONDS=120
